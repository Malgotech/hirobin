<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Allow cleartext ws:// to the dev backend on the host machine (debug only). -->
    <application android:usesCleartextTraffic="true">
        <!-- Debug-only receiver: trigger a fake incoming call via ADB.
             adb shell am broadcast -a com.yourcompany.hirobin.DEBUG_INCOMING_CALL
               -e number 5551234 -n com.yourcompany.hirobin/.DebugCallReceiver
        -->
        <receiver
            android:name=".DebugCallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.yourcompany.hirobin.DEBUG_INCOMING_CALL" />
                <action android:name="com.yourcompany.hirobin.DEBUG_ANSWER_CALL" />
                <action android:name="com.yourcompany.hirobin.DEBUG_HANGUP_CALL" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
